{
  "name": "amber-agents",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted control plane for remote CLI agents (Phase 0)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n daemon,web -c blue,green \"pnpm dev:daemon\" \"pnpm dev:web\"",
    "dev:daemon": "pnpm --filter @amber/daemon dev",
    "dev:web": "pnpm --filter @amber/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "postinstall": "node scripts/fix-node-pty.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af"
}
